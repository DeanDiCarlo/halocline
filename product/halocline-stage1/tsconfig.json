{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["api/**/*.ts", "app/**/*.ts", "scripts/**/*.ts", "src/**/*.ts", "tests/**/*.ts", "vite.config.ts"]
}
